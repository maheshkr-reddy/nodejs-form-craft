<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FormCraft — Visual Form Builder</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/builder.css">
</head>
<body>
  <!-- TOP BAR -->
  <header class="topbar">
    <div class="topbar-left">
      <div class="logo">
        <span class="logo-icon">⬡</span>
        <span class="logo-text">FormCraft</span>
      </div>
      <div class="form-name-wrap hide-on-mobile">
        <input type="text" id="formName" class="form-name-input" value="Untitled Form" spellcheck="false">
      </div>
    </div>
    <div class="topbar-center">
      <div class="mode-tabs">
        <button class="mode-tab active" data-mode="build">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          Build
        </button>
        <button class="mode-tab" data-mode="preview">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          Preview
        </button>
        <button class="mode-tab" data-mode="json">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          JSON
        </button>
      </div>
    </div>
    <div class="topbar-right">
      <div class="import-wrap hide-on-mobile">
        <button class="btn-ghost" id="importBtn" title="Import schema">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          <span>Import</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-left:2px"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="import-menu" id="importMenu">
          <button class="import-menu-item" data-import="file">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <div class="import-menu-text">
              <div class="import-menu-title">From File</div>
              <div class="import-menu-sub">Upload a JSON schema file</div>
            </div>
          </button>
          <button class="import-menu-item" data-import="url">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            <div class="import-menu-text">
              <div class="import-menu-title">From URL</div>
              <div class="import-menu-sub">Fetch JSON from a URL</div>
            </div>
          </button>
        </div>
      </div>
      <input type="file" id="importFileInput" accept=".json,application/json" style="display:none">
      <button class="btn-ghost hide-on-mobile" id="clearBtn">Clear</button>
      <button class="btn-primary" id="saveBtn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        <span class="hide-on-mobile-inline">Save Form</span>
      </button>
    </div>

    <!-- Import URL modal -->
    <div class="modal-overlay" id="urlModal" style="display:none">
      <div class="modal-card">
        <div class="modal-header">
          <h3>Import Schema from URL</h3>
          <button class="modal-close" id="urlModalClose" type="button">×</button>
        </div>
        <div class="modal-body">
          <label class="modal-label">URL</label>
          <input type="url" id="urlInput" class="modal-input" placeholder="https://example.com/schema.json" spellcheck="false">
          <p class="modal-hint">The URL must return a JSON response. CORS must be allowed by the remote server.</p>
        </div>
        <div class="modal-footer">
          <button class="btn-ghost" id="urlModalCancel" type="button">Cancel</button>
          <button class="btn-primary" id="urlModalLoad" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            Load
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- Mobile panel toggle (only shown on small screens) -->
  <div class="mobile-panel-bar" id="mobilePanelBar">
    <button class="mobile-panel-btn" data-mobile-panel="elements">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      Elements
    </button>
    <button class="mobile-panel-btn active" data-mobile-panel="canvas">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="2" y1="9" x2="22" y2="9"/></svg>
      Canvas
    </button>
    <button class="mobile-panel-btn" data-mobile-panel="props">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      Properties
    </button>
  </div>

  <div class="workspace" id="workspace">
    <!-- LEFT: ELEMENTS PANEL (GRID) -->
    <aside class="panel panel-elements" id="elementsPanel">
      <div class="panel-header">
        <span class="panel-title">Elements</span>
        <div class="search-wrap">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="elementSearch" placeholder="Search elements..." class="element-search">
        </div>
      </div>
      <div class="elements-list" id="elementsList">
        <div class="element-group">
          <div class="group-label">Basic Inputs</div>
          <div class="element-grid">
            <div class="element-item" draggable="true" data-type="text">
              <span class="el-icon">Aa</span>
              <span class="el-label">Text Input</span>
            </div>
            <div class="element-item" draggable="true" data-type="email">
              <span class="el-icon">@</span>
              <span class="el-label">Email</span>
            </div>
            <div class="element-item" draggable="true" data-type="number">
              <span class="el-icon">№</span>
              <span class="el-label">Number</span>
            </div>
            <div class="element-item" draggable="true" data-type="password">
              <span class="el-icon">••</span>
              <span class="el-label">Password</span>
            </div>
            <div class="element-item" draggable="true" data-type="tel">
              <span class="el-icon">☏</span>
              <span class="el-label">Phone</span>
            </div>
            <div class="element-item" draggable="true" data-type="url">
              <span class="el-icon">⌘</span>
              <span class="el-label">URL</span>
            </div>
          </div>
        </div>
        <div class="element-group">
          <div class="group-label">Text Areas</div>
          <div class="element-grid">
            <div class="element-item" draggable="true" data-type="textarea">
              <span class="el-icon">¶</span>
              <span class="el-label">Textarea</span>
            </div>
            <div class="element-item" draggable="true" data-type="richtext">
              <span class="el-icon">B/</span>
              <span class="el-label">Rich Text</span>
            </div>
          </div>
        </div>
        <div class="element-group">
          <div class="group-label">Selection</div>
          <div class="element-grid">
            <div class="element-item" draggable="true" data-type="select">
              <span class="el-icon">▾</span>
              <span class="el-label">Dropdown</span>
            </div>
            <div class="element-item" draggable="true" data-type="multiselect">
              <span class="el-icon">▾▾</span>
              <span class="el-label">Multi-Select</span>
            </div>
            <div class="element-item" draggable="true" data-type="radio">
              <span class="el-icon">◉</span>
              <span class="el-label">Radio</span>
            </div>
            <div class="element-item" draggable="true" data-type="checkbox">
              <span class="el-icon">☑</span>
              <span class="el-label">Checkbox</span>
            </div>
            <div class="element-item" draggable="true" data-type="checkboxgroup">
              <span class="el-icon">☑☑</span>
              <span class="el-label">Checkbox Group</span>
            </div>
            <div class="element-item" draggable="true" data-type="toggle">
              <span class="el-icon">⏻</span>
              <span class="el-label">Toggle</span>
            </div>
          </div>
        </div>
        <div class="element-group">
          <div class="group-label">Date & Time</div>
          <div class="element-grid">
            <div class="element-item" draggable="true" data-type="date">
              <span class="el-icon">📅</span>
              <span class="el-label">Date</span>
            </div>
            <div class="element-item" draggable="true" data-type="time">
              <span class="el-icon">⏱</span>
              <span class="el-label">Time</span>
            </div>
            <div class="element-item" draggable="true" data-type="datetime-local">
              <span class="el-icon">🗓</span>
              <span class="el-label">Date & Time</span>
            </div>
          </div>
        </div>
        <div class="element-group">
          <div class="group-label">Advanced</div>
          <div class="element-grid">
            <div class="element-item" draggable="true" data-type="range">
              <span class="el-icon">━</span>
              <span class="el-label">Slider</span>
            </div>
            <div class="element-item" draggable="true" data-type="rangeslider">
              <span class="el-icon">⇆</span>
              <span class="el-label">Range Slider</span>
            </div>
            <div class="element-item" draggable="true" data-type="rating">
              <span class="el-icon">★</span>
              <span class="el-label">Rating</span>
            </div>
            <div class="element-item" draggable="true" data-type="file">
              <span class="el-icon">↑</span>
              <span class="el-label">File Upload</span>
            </div>
            <div class="element-item" draggable="true" data-type="color">
              <span class="el-icon">◐</span>
              <span class="el-label">Color</span>
            </div>
          </div>
        </div>
        <div class="element-group">
          <div class="group-label">Layout</div>
          <div class="element-grid">
            <div class="element-item" draggable="true" data-type="heading">
              <span class="el-icon">H1</span>
              <span class="el-label">Heading</span>
            </div>
            <div class="element-item" draggable="true" data-type="paragraph">
              <span class="el-icon">¶</span>
              <span class="el-label">Paragraph</span>
            </div>
            <div class="element-item" draggable="true" data-type="divider">
              <span class="el-icon">—</span>
              <span class="el-label">Divider</span>
            </div>
            <div class="element-item" draggable="true" data-type="columns">
              <span class="el-icon">⫩</span>
              <span class="el-label">Two Columns</span>
            </div>
            <div class="element-item" draggable="true" data-type="submit">
              <span class="el-icon">▶</span>
              <span class="el-label">Submit</span>
            </div>
          </div>
        </div>
      </div>
    </aside>

    <!-- CENTER: CANVAS -->
    <main class="canvas-wrap" id="canvasWrap">
      <!-- Build Mode -->
      <div class="canvas-mode active" id="buildMode">
        <!-- Form tabs bar (visible when more than one tab exists) -->
        <div class="form-tabs-bar" id="formTabsBar"></div>
        <div class="canvas-toolbar">
          <span class="canvas-info" id="fieldCount">0 fields</span>
          <div class="canvas-actions">
            <button class="canvas-btn" id="undoBtn" title="Undo">↩</button>
            <button class="canvas-btn" id="redoBtn" title="Redo">↪</button>
          </div>
        </div>
        <div class="canvas" id="formCanvas">
          <div class="canvas-empty" id="canvasEmpty">
            <div class="empty-icon">⬡</div>
            <div class="empty-title">Drag elements here</div>
            <div class="empty-sub">or click any element from the left panel to add it to this tab</div>
          </div>
        </div>
      </div>

      <!-- Preview Mode -->
      <div class="canvas-mode" id="previewMode">
        <div class="preview-toolbar">
          <div class="toolbar-row">
            <div class="toolbar-section">
              <span class="toolbar-label">Template</span>
              <div class="toolbar-options" id="templateOptions">
                <button class="toolbar-opt active" data-template="horizontal-tabs" title="Horizontal Tabs">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="6" x2="9" y2="6"/></svg>
                  <span>Horizontal</span>
                </button>
                <button class="toolbar-opt" data-template="vertical-tabs" title="Vertical Tabs">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="9" y1="3" x2="9" y2="21"/><line x1="6" y1="3" x2="6" y2="9"/></svg>
                  <span>Vertical</span>
                </button>
                <button class="toolbar-opt" data-template="accordion" title="Accordion">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="4"/><rect x="3" y="10" width="18" height="4"/><rect x="3" y="16" width="18" height="4"/></svg>
                  <span>Accordion</span>
                </button>
                <button class="toolbar-opt" data-template="stepper" title="Stepper / Wizard">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="19" cy="12" r="2"/><line x1="7" y1="12" x2="10" y2="12"/><line x1="14" y1="12" x2="17" y2="12"/></svg>
                  <span>Stepper</span>
                </button>
                <button class="toolbar-opt" data-template="single-page" title="Single Page">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="3" width="16" height="18" rx="2"/></svg>
                  <span>Single Page</span>
                </button>
              </div>
            </div>
          </div>
          <div class="toolbar-row">
            <div class="toolbar-section">
              <span class="toolbar-label">Width</span>
              <div class="toolbar-options" id="widthOptions">
                <button class="toolbar-opt" data-width="sm">Small</button>
                <button class="toolbar-opt active" data-width="md">Medium</button>
                <button class="toolbar-opt" data-width="lg">Large</button>
                <button class="toolbar-opt" data-width="xl">XL</button>
                <button class="toolbar-opt" data-width="xxl">XXL</button>
                <button class="toolbar-opt" data-width="full">Full</button>
              </div>
            </div>
            <div class="toolbar-section">
              <span class="toolbar-label">Style</span>
              <div class="toolbar-options" id="styleOptions">
                <button class="toolbar-toggle active" data-style="border">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                  Border
                </button>
                <button class="toolbar-toggle active" data-style="shadow">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="5" width="14" height="14" rx="2"/><path d="M21 9v10a2 2 0 0 1-2 2H9"/></svg>
                  Shadow
                </button>
                <button class="toolbar-toggle active" data-style="rounded">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12V6a2 2 0 0 1 2-2h6"/><path d="M20 12v6a2 2 0 0 1-2 2h-6"/></svg>
                  Rounded
                </button>
              </div>
            </div>
            <div class="toolbar-section toolbar-section-end">
              <div class="export-wrap">
                <button class="btn-primary export-btn" id="exportBtn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  Export
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <div class="export-menu" id="exportMenu">
                  <button class="export-opt" data-export="html">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                    <div><div class="export-opt-title">HTML</div><div class="export-opt-sub">Standalone .html file</div></div>
                  </button>
                  <button class="export-opt" data-export="pdf">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <div><div class="export-opt-title">PDF</div><div class="export-opt-sub">Printable document</div></div>
                  </button>
                  <button class="export-opt" data-export="image">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <div><div class="export-opt-title">Image</div><div class="export-opt-sub">PNG screenshot</div></div>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="preview-container" id="previewContainer">
          <div class="preview-header">
            <span class="preview-badge">Preview</span>
            <h2 class="preview-form-title" id="previewTitle">Untitled Form</h2>
          </div>
          <div class="preview-form" id="previewForm"></div>
        </div>
      </div>

      <!-- JSON Mode -->
      <div class="canvas-mode" id="jsonMode">
        <div class="json-container">
          <div class="json-toolbar">
            <span class="json-label">Form Schema</span>
            <button class="btn-ghost sm" id="copyJsonBtn">Copy JSON</button>
          </div>
          <pre class="json-output" id="jsonOutput"></pre>
        </div>
      </div>
    </main>

    <!-- RIGHT: PROPERTIES PANEL -->
    <aside class="panel panel-props" id="propsPanel">
      <div class="panel-header">
        <span class="panel-title">Properties</span>
        <span class="selected-type" id="selectedType">—</span>
      </div>
      <div class="props-empty" id="propsEmpty">
        <div class="props-empty-icon">↖</div>
        <div class="props-empty-text">Select a field to edit its properties</div>
      </div>
      <div class="props-form" id="propsForm" style="display:none"></div>
    </aside>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <!-- Export libs -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="/js/builder.js"></script>
</body>
</html>
